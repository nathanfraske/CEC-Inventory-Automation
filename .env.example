# Copy to .env, then run ./scripts/gen_secrets.sh to fill the secret values.
# .env is gitignored and must NEVER be committed. This file (.env.example) carries
# only placeholders and IS committed.

# ---- Postgres ----
POSTGRES_USER=cec
POSTGRES_PASSWORD=CHANGE_ME_RUN_gen_secrets
POSTGRES_DB=cec_inventory
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Connection string for the Rust services. Contains the password, so this is a secret.
# App-in-container uses host 'db' (the compose service); host-run dev uses 'localhost'.
DATABASE_URL=postgres://cec:CHANGE_ME_RUN_gen_secrets@localhost:5432/cec_inventory

# ---- API ----
API_BIND=0.0.0.0:8080
# Host port the api container publishes on (container-internal port stays 8080).
# Override when 8080 is already in use on the box, e.g. by the cec-llm-broker.
API_PUBLISH_PORT=8080
SESSION_SECRET=CHANGE_ME_64_HEX
RUST_LOG=info,cec_inventory_api=debug

# ---- Object storage (filesystem default; flip if INV-OQ-2 changes) ----
STORAGE_BACKEND=fs
STORAGE_FS_ROOT=/var/lib/cec-inventory/objects
# MINIO_ENDPOINT=http://minio:9000
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=cec-inventory

# ---- Extraction + stitching service (runs on the inference box) ----
EXTRACTOR_URL=http://inference-box:8900
# Vision backend for receipt IMAGES (scope §11.2). 'stub' (default) keeps the build hermetic.
# 'openai' targets an OpenAI-compatible /chat/completions endpoint — point EXTRACTOR_VLM_BASE_URL
# at the on-box cec-llm-broker to keep receipt images on-prem. 'claude' is the interim hosted path.
# All are passed through to the extractor container by docker-compose.
EXTRACTOR_VLM_BACKEND=stub          # stub|openai|claude
EXTRACTOR_VLM_MODEL=                # vision model id (e.g. cec-worker-vision for the broker)
# -- openai backend (local broker / any OpenAI-compatible VLM server) --
EXTRACTOR_VLM_BASE_URL=             # e.g. http://host.docker.internal:8080/v1 (cec-llm-broker)
EXTRACTOR_VLM_API_KEY=              # optional bearer token; many local servers accept any/none
EXTRACTOR_VLM_MAX_TOKENS=2048
EXTRACTOR_VLM_TIMEOUT=600           # seconds; generous to ride through a cold model load
EXTRACTOR_VLM_MAX_IMAGE_BYTES=16777216   # refuse receipt images larger than this before VLM egress
# -- claude backend (interim hosted vision) --
ANTHROPIC_API_KEY=                  # SECRET; required when =claude. Never commit a real value.
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ---- Carrier tracking: the single external dependency (INV-OQ-30) ----
# none until a provider is chosen. direct carrier APIs OR one aggregator.
CARRIER_PROVIDER=none   # none|usps|ups|fedex|dhl|easypost|aftership|ship24
CARRIER_API_KEY=
CARRIER_API_SECRET=
SHIPMENT_POLL_INTERVAL_SECS=10800

# ---- Backups (DB + receipt object store) — see scripts/db_backup.sh + SECRETS-AND-DATABASE.md ----
BACKUP_DIR=/var/backups/cec-inventory
# age PUBLIC key to encrypt backups at rest (generate with: age-keygen -o backup-age.key).
BACKUP_AGE_RECIPIENT=
# age PRIVATE key, needed only to RESTORE. Keep OFF-repo and backed up separately — without it
# the encrypted archives are unrecoverable. NEVER commit a real key.
BACKUP_AGE_IDENTITY=
BACKUP_RETENTION_DAYS=30
# Optional: replicate each run's encrypted archives to a second failure domain (a different disk,
# a mount, or on WSL2 a /mnt/c Windows path). Encrypted .age files only, by default.
# BACKUP_OFFSITE_DIR=/mnt/c/CEC-Backups
# Optional: ALSO mirror the age private key to BACKUP_OFFSITE_DIR so it alone can restore. This
# co-locates the key with the ciphertext it decrypts — only enable on a destination you trust as
# much as the box. Leave unset to keep the offsite copy ciphertext-only.
# BACKUP_OFFSITE_INCLUDE_KEY=1
