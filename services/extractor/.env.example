# Extractor + stitching service (Python, runs on the inference box). Copy to .env there.
# Gitignored. The only secret here is ANTHROPIC_API_KEY (interim hosted-vision path) — never
# commit a real value.
EXTRACTOR_BIND=0.0.0.0:8900
MODEL_BACKEND=vllm            # vllm|llamacpp|ollama (local VLM, scope §11.2)
MODEL_ID=Qwen2.5-VL-7B-Instruct
DEVICE=cuda                   # cuda|cpu
TEMPLATE_DIR=./templates      # invoice2data vendor templates

# ---- Image vision backend (scope §11.2) ----
# 'stub' (default) returns an empty result so the build/CI stay hermetic.
# 'openai' POSTs the image to an OpenAI-compatible /chat/completions endpoint — point
#   EXTRACTOR_VLM_BASE_URL at the on-box cec-llm-broker to keep receipt images on-prem (§11.2).
# 'claude' POSTs the image to the Anthropic Messages API (interim hosted VLM).
EXTRACTOR_VLM_BACKEND=stub    # stub|openai|claude
EXTRACTOR_VLM_MODEL=          # vision model id (e.g. cec-worker-vision for the broker)
# -- openai backend --
EXTRACTOR_VLM_BASE_URL=       # e.g. http://host.docker.internal:8080/v1 (cec-llm-broker)
EXTRACTOR_VLM_API_KEY=        # optional bearer token; many local servers accept any/none
EXTRACTOR_VLM_MAX_TOKENS=2048
EXTRACTOR_VLM_TIMEOUT=600     # seconds; generous to ride through a cold model load
# -- claude backend --
ANTHROPIC_API_KEY=            # SECRET; required when =claude
# ANTHROPIC_BASE_URL=https://api.anthropic.com
