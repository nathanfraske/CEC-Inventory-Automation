# Extractor + stitching service (Python, runs on the inference box). Copy to .env there.
# Gitignored. The only secret here is ANTHROPIC_API_KEY (interim hosted-vision path) — never
# commit a real value.
EXTRACTOR_BIND=0.0.0.0:8900
MODEL_BACKEND=vllm            # vllm|llamacpp|ollama (local VLM, scope §11.2)
MODEL_ID=Qwen2.5-VL-7B-Instruct
DEVICE=cuda                   # cuda|cpu
TEMPLATE_DIR=./templates      # invoice2data vendor templates

# ---- Image vision backend (scope §11.2) ----
# 'stub' (default) returns an empty result so the build/CI stay hermetic. 'claude' POSTs the
# receipt image to the Anthropic Messages API as an interim VLM until the local model is wired.
EXTRACTOR_VLM_BACKEND=stub    # stub|claude
EXTRACTOR_VLM_MODEL=          # required when =claude: a vision-capable model id
ANTHROPIC_API_KEY=            # SECRET; required when =claude
# ANTHROPIC_BASE_URL=https://api.anthropic.com
